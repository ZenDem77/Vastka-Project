<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="#3D5AFE">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Orders"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"/>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Pending Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textColor="#999999"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <!-- Pending orders injected here -->
            <LinearLayout
                android:id="@+id/pendingContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Empty state for pending -->
            <TextView
                android:id="@+id/tvNoPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No pending orders"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Completed Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Completed"
                android:textColor="#999999"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp"/>

            <!-- Completed orders injected here -->
            <LinearLayout
                android:id="@+id/completedContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Empty state for completed -->
            <TextView
                android:id="@+id/tvNoCompleted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No completed orders yet"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>